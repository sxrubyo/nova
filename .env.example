# Nova OS public repo template
# Copy this file to `.env` and replace placeholders before any real deployment.

# Core
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3005
CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://localhost:5173,http://127.0.0.1:5173

# Database
POSTGRES_DB=nova
POSTGRES_USER=nova
POSTGRES_PASSWORD=change_me_local_dev_only
DATABASE_URL=postgresql://nova:change_me_local_dev_only@db:5432/nova

# API security
SECRET_KEY=change_me_to_a_long_random_secret
WORKSPACE_ADMIN_TOKEN=change_me_to_a_long_random_admin_token
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_NAME=nova_session
SESSION_TTL_HOURS=8

# Optional GitHub OAuth for web login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback
GITHUB_SCOPE=read:user user:email

# Optional LLM providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=

# Frontend optional overrides
VITE_SERVER_ORIGIN=
VITE_API_BASE_PATH=
VITE_GITHUB_AUTH_URL=
