# Nova OS Configuration
NOVA_ENV=development
NOVA_VERSION=4.0.0
NOVA_HOST=0.0.0.0
NOVA_API_PORT=9800
NOVA_BRIDGE_PORT=9700
NOVA_LOG_LEVEL=INFO
NOVA_LOG_FORMAT=json

# Database
NOVA_DB_URL=sqlite+aiosqlite:///./nova.db
# NOVA_DB_URL=postgresql+asyncpg://user:pass@localhost:5432/nova

# Security
NOVA_JWT_SECRET=your-secret-key-change-in-production
NOVA_JWT_ALGORITHM=HS256
NOVA_JWT_EXPIRY_HOURS=24
NOVA_API_KEY_PREFIX=nova_

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=

# Risk Engine Defaults
NOVA_RISK_AUTO_ALLOW_THRESHOLD=30
NOVA_RISK_ESCALATE_THRESHOLD=60
NOVA_RISK_AUTO_BLOCK_THRESHOLD=80

# Rate Limiting
NOVA_RATE_LIMIT_PER_MINUTE=100
NOVA_RATE_LIMIT_BURST=20

# Anomaly Detection
NOVA_ANOMALY_BURST_THRESHOLD=50
NOVA_ANOMALY_LOOP_SIMILARITY=0.85
NOVA_ANOMALY_CHECK_INTERVAL=30
