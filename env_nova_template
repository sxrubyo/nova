# ══════════════════════════════════════════════════════════════════════════════
#  Nova Core v3.1  —  .env  (TEMPLATE — no hardcoded keys)
#  Copy to: /home/ubuntu/nova/.env
#  Then fill in your actual API keys
# ══════════════════════════════════════════════════════════════════════════════

# ── Nova server ───────────────────────────────────────────────────────────────
NOVA_PORT=9003
NOVA_API_KEY=change_this_to_a_strong_random_key
NOVA_SECRET_KEY=change_this_to_another_strong_key
NOVA_DEV_MODE=false
NOVA_FAIL_OPEN=true

# ── Rule folder + ledger ──────────────────────────────────────────────────────
NOVA_RULES_DIR=./nova_rules
NOVA_DB_PATH=./nova.db

# ── LLM provider (pick ONE, comment the others) ───────────────────────────────

# Option A: OpenRouter (access to all models)
NOVA_LLM_PROVIDER=openrouter
NOVA_LLM_MODEL=google/gemini-2.5-flash
NOVA_LLM_API_KEY=your_openrouter_key_here
# Also set this for nova CLI to pick up automatically:
OPENROUTER_API_KEY=your_openrouter_key_here

# Option B: Anthropic (Claude)
# NOVA_LLM_PROVIDER=anthropic
# NOVA_LLM_MODEL=claude-sonnet-4-6
# NOVA_LLM_API_KEY=your_anthropic_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Option C: Groq (fast, free tier)
# NOVA_LLM_PROVIDER=groq
# NOVA_LLM_MODEL=llama-3.3-70b-versatile
# NOVA_LLM_API_KEY=your_groq_key_here
# GROQ_API_KEY=your_groq_key_here

# Option D: Gemini direct (Google AI Studio)
# NOVA_LLM_PROVIDER=gemini
# NOVA_LLM_MODEL=gemini-2.0-flash
# NOVA_LLM_API_KEY=your_gemini_key_here
# GEMINI_API_KEY=your_gemini_key_here

# Option E: Ollama (fully local, no API key needed)
# NOVA_LLM_PROVIDER=ollama
# NOVA_LLM_MODEL=qwen3.5:27b
# NOVA_LLM_BASE_URL=http://localhost:11434

# Option F: OpenClaw or any OpenAI-compatible endpoint
# NOVA_LLM_PROVIDER=openclaw
# NOVA_LLM_MODEL=your-model-name
# NOVA_LLM_BASE_URL=http://localhost:1234/v1
# NOVA_LLM_API_KEY=your_key_or_empty

# ── Agent to govern (auto-discovered if blank) ────────────────────────────────
NOVA_AGENT_URL=
NOVA_AGENT_NAME=agent

# ── Governance thresholds (tunable) ──────────────────────────────────────────
NOVA_SCORE_BLOCK=40
NOVA_SCORE_ESCALATE=68
NOVA_ANOMALY_BURST=20
NOVA_ANOMALY_BLOCKRATE=0.5
NOVA_ANOMALY_SCORE_DROP=15
NOVA_DEDUP_WINDOW=60
NOVA_DEDUP_THRESHOLD=0.82
NOVA_RATE_LIMIT=200

# ── Logging ───────────────────────────────────────────────────────────────────
NOVA_LOG_LEVEL=INFO
